{
  "_doc": "Plugin-root hook manifest for the Codex plugin system. Commands are RELATIVE to the plugin dir (the figma-plugin convention), so Codex auto-wires + auto-manages them on plugin install/uninstall — giving lifecycle isolation for free. This is the plugin-install path. The manual-install path uses `node scripts/install.js`, which marker-merges absolute-path entries from hooks/hooks.json into the global ~/.codex/hooks.json instead. scripts/tests/drift.test.js asserts these two wirings never diverge.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          { "type": "command", "command": "bash \"./hooks/session-start-check.sh\"", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"./hooks/pre-bash-safety-check.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/banned-vocab-check.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/ship-baseline-check.sh\"", "timeout": 8 },
          { "type": "command", "command": "bash \"./hooks/memory-read-check.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/secrets-scan.sh\"", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"./hooks/surface-advisories.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/memory-prompt-hint.sh\"", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"./hooks/residue-audit.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/sandbox-disposal-check.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"./hooks/transcript-structure-scan.sh\"", "timeout": 5 },
          { "type": "command", "command": "bash \"./hooks/convention-cite-scan.sh\"", "timeout": 5 }
        ]
      }
    ]
  }
}
